<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.aiclean.mapper.ExportBatchMapper">

    <resultMap id="BaseResultMap" type="com.aiclean.entity.ExportBatchEntity">
        <id column="id" property="id"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
        <result column="batch_name" property="batchName"/>
        <result column="export_type" property="exportType"/>
        <result column="format" property="format"/>
        <result column="file_name" property="fileName"/>
        <result column="file_path" property="filePath"/>
        <result column="file_size" property="fileSize"/>
        <result column="total_records" property="totalRecords"/>
        <result column="exported_records" property="exportedRecords"/>
        <result column="status" property="status"/>
        <result column="error_message" property="errorMessage"/>
        <result column="exported_by" property="exportedBy"/>
        <result column="exported_at" property="exportedAt"/>
        <result column="category_ids" property="categoryIds"/>
    </resultMap>

    <select id="selectByCategoryIds" resultMap="BaseResultMap">
        SELECT DISTINCT eb.* FROM export_batch eb
        WHERE 1=1
        <if test="categoryIds != null and categoryIds.size() > 0">
            AND eb.id IN (
                SELECT DISTINCT cb.export_batch_id FROM cleaned_data cb
                WHERE cb.category_id IN
                <foreach collection="categoryIds" item="catId" open="(" separator="," close=")">
                    #{catId}
                </foreach>
                AND cb.export_batch_id IS NOT NULL
            )
        </if>
        ORDER BY eb.created_at DESC
    </select>

</mapper>
